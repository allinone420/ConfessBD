{
  "entities": {
    "Confession": {
      "title": "Confession",
      "description": "An anonymous confession post",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The content of the confession"
        },
        "area": {
          "type": "string",
          "description": "The location/area tag"
        },
        "likes": {
          "type": "number",
          "description": "Number of likes"
        },
        "commentsCount": {
          "type": "number",
          "description": "Number of comments"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Creation time"
        },
        "secretId": {
          "type": "string",
          "description": "Auto-generated anonymous ID (e.g. Secret #1234)"
        },
        "reports": {
          "type": "number",
          "description": "Number of reports"
        }
      },
      "required": ["text", "area", "timestamp", "secretId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "An anonymous comment on a confession",
      "type": "object",
      "properties": {
        "confessionId": {
          "type": "string",
          "description": "ID of the parent confession"
        },
        "text": {
          "type": "string",
          "description": "The content of the comment"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Creation time"
        }
      },
      "required": ["confessionId", "text", "timestamp"]
    }
  },
  "firestore": {
    "/confessions/{confessionId}": {
      "schema": "Confession",
      "description": "Collection of anonymous confessions"
    },
    "/confessions/{confessionId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Subcollection of comments for a confession"
    }
  }
}
